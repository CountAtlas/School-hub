# ── API Server (Railway / Render / local) ──────────────────────────────────────

# Required: PostgreSQL connection string (Supabase Postgres, Railway Postgres, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required: random secret for express-session cookie signing (generate with: openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-random-secret

# Required: server port
PORT=8080

# Required: initial admin account — only used once to seed the DB if no admins exist
ADMIN_PASSWORD=your-admin-password

# Optional: Supabase project URL (enables cloud file storage instead of local disk)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Optional: Supabase service role key (secret — keep this private, server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: allowed CORS origin in production (e.g. your Vercel frontend URL)
# Leave unset to allow all origins (fine for development)
ALLOWED_ORIGIN=https://school-hub.vercel.app


# ── Frontend (Vercel) ──────────────────────────────────────────────────────────

# Optional: full URL of the API server (leave empty for relative /api calls in local dev)
VITE_API_URL=https://school-hub-api.railway.app
